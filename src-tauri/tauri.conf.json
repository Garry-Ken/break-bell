{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BreakBell",
  "version": "0.1.1",
  "identifier": "com.garry.breakbell",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5192",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "歇钟",
        "width": 460,
        "height": 760,
        "minWidth": 420,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
